import java.util.Scanner;

public class ExamSeatingPlan {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int rows = sc.nextInt();
        int cols = sc.nextInt();
        int totalStudents = sc.nextInt();

        int totalSeats = rows * cols;
        int student = 1;

        System.out.println("Exam Seating Plan:");

        for(int i = 0; i < rows * 2; i++) {
            for(int j = 0; j < cols; j++) {

                if((i + j) % 2 == 0 && student <= totalStudents) {
                    System.out.printf("S%03d ", student);
                    student++;
                } 
                else {
                    System.out.print("---- ");
                }

            }
            System.out.println();
        }

        System.out.println();
        System.out.println("Total Seats: " + totalSeats);
        System.out.println("Occupied Seats: " + totalStudents);
        System.out.println("Empty Seats: " + (totalSeats - totalStudents));
    }
}
