class Solution {
    public int removeDuplicates(int[] nums) {
        int a=0;
        int b=1;
        for(int i=0;i<nums.length-1;i++){
            if(nums[a]!=nums[b]){
               a++;
               nums[a]=nums[b];
            }
            b++;
           }
           return a+1;
        }
    }
